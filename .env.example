# Model provider: "codex" or "claude"
AUTORESEARCH_MODEL_PROVIDER=codex

# Path to the codex CLI binary
AUTORESEARCH_CODEX_BIN=codex

# Path to the claude CLI binary
AUTORESEARCH_CLAUDE_BIN=claude

# Reasoning effort for Codex models (low, medium, high)
AUTORESEARCH_REASONING_EFFORT=high

# Reasoning effort for Claude models (low, medium, high)
AUTORESEARCH_CLAUDE_EFFORT=high

# Project directory for the strategy factory loop
FACTORY_PROJECT_DIR=./live-run

# Interval in seconds between factory optimization cycles
FACTORY_CYCLE_SECONDS=600
